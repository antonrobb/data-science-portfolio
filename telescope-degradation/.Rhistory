y = r_double_in * sin(seq(0, 2*pi, l=200))) +
annotate("path", color = "black",
x = r_double_out * cos(seq(0, 2*pi, l=200)),
y = r_double_out * sin(seq(0, 2*pi, l=200))) +
# The 20 radial lines dividing the sectors
