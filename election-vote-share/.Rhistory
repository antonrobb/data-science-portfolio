ggplot(data.frame(mjd = monthly$mjd, r = residuals(m_linear)),
aes(mjd, r)) +
geom_point(colour = "dodgerblue3", size = 0.8) +
geom_hline(yintercept = 0, colour = "darkorange2") +
labs(title = "Monthly residuals from the constant-rate model",
x = "Modified Julian Date (MJD)", y = "Residual (log scale)") +
theme_minimal()
library(lubridate)
# Reconstruct a calendar date from MJD (MJD epoch: 1858-11-17)
tel_clean <- tel[tel$keep, ]
tel_clean$date  <- as.Date(tel_clean$mjd, origin = as.Date("1858-11-17"))
tel_clean$month <- floor_date(tel_clean$date, "month")
monthly <- tel_clean %>%
group_by(month, segment) %>%
summarise(mjd = mean(mjd), log_trans = mean(log_trans), n = n(),
.groups = "drop")
m_linear <- lm(log_trans ~ mjd + segment, data = monthly)
m_quad   <- lm(log_trans ~ mjd + I(mjd^2) + segment, data = monthly)
anova(m_linear, m_quad)
summary(m_quad)$coefficients["I(mjd^2)", ]
ggplot(data.frame(mjd = monthly$mjd, r = residuals(m_linear)),
aes(mjd, r)) +
geom_point(colour = "dodgerblue3", size = 0.8) +
geom_hline(yintercept = 0, colour = "darkorange2") +
labs(title = "Monthly residuals from the constant-rate model",
x = "Modified Julian Date (MJD)", y = "Residual (log scale)") +
theme_minimal()
latest_seg <- tail(levels(monthly$segment), 1)
newdata <- data.frame(mjd = 61041,
segment = factor(latest_seg, levels = levels(monthly$segment)))
pred <- predict(m_quad, newdata = newdata, interval = "confidence", level = 0.95)
exp(pred)
future_mjd <- seq(max(monthly$mjd), max(monthly$mjd) + 2000, by = 1)
future <- data.frame(mjd = future_mjd,
segment = factor(latest_seg, levels = levels(monthly$segment)))
fp <- exp(predict(m_quad, newdata = future, interval = "confidence", level = 0.95))
threshold <- 0.15
cross <- data.frame(
fit   = future_mjd[which(fp[, "fit"] < threshold)[1]],
lower = future_mjd[which(fp[, "upr"] < threshold)[1]],
upper = future_mjd[which(fp[, "lwr"] < threshold)[1]]
)
cross
as.Date(unlist(cross), origin = as.Date("1858-11-17"))
tel$log_trans <- log(tel$trans)
tel$segment <- cut(tel$mjd,
breaks = c(min(tel$mjd), cleans, max(tel$mjd)),
include.lowest = TRUE)
model <- lm(log_trans ~ mjd + segment, data = tel)
tel$fit <- exp(predict(model))
ggplot(tel, aes(mjd, trans)) +
geom_point(size = 0.4, alpha = 0.4, colour = "dodgerblue3") +
geom_line(aes(y = fit), colour = "seagreen", linewidth = 0.7) +
labs(title = "Transmission with fitted exponential-decay model",
x = "Modified Julian Date (MJD)", y = "Transmission") +
theme_minimal()
tel$pred_trans <- exp(predict(model_clean, newdata = tel))
ggplot(tel, aes(mjd, trans, colour = keep)) +
geom_point(size = 0.5, alpha = 0.5) +
geom_line(aes(y = pred_trans), colour = "seagreen", linewidth = 0.7) +
scale_colour_manual(values = c("TRUE" = "dodgerblue3", "FALSE" = "darkorange2"),
labels = c("TRUE" = "Retained", "FALSE" = "Removed (cloud)"),
name = NULL) +
labs(title = "Cleaned data with refitted model",
x = "Modified Julian Date (MJD)", y = "Transmission") +
theme_minimal()
setwd("C:/Users/ntnrb/Projects/data-science-portfolio/election-vote-share")
knitr::opts_chunk$set(echo = TRUE, message = FALSE, warning = FALSE,
fig.width = 7, fig.height = 5)
library(dplyr)
elec  <- read.csv("election2024.csv", fileEncoding = enc)
library(dplyr)
elec  <- read.csv("election2024.csv")
library(dplyr)
elec  <- read.csv("election2024.csv")
age   <- read.csv("age.csv")
claim <- read.csv("claimants.csv")
eth   <- read.csv("ethnicity.csv")
qual  <- read.csv("qualifications.csv")
wage  <- read.csv("wages.csv")
# Retain a small, non-redundant set of explanatory variables per domain
age   <- age[,   c("ONSConstID", "pct18.24", "pct65.up")]
claim <- claim[, c("ONSConstID", "claimant_rate")]
eth   <- eth[,   c("ONSConstID", "white", "asian", "black")]
qual  <- qual[,  c("ONSConstID", "Qual4_pct", "Qual5_pct")]
wage  <- wage[,  c("ONSConstID", "MedianWage")]
elec$Region <- factor(elec$RegionName)
df <- elec |>
merge(age,   by = "ONSConstID") |>
merge(claim, by = "ONSConstID") |>
merge(eth,   by = "ONSConstID") |>
merge(qual,  by = "ONSConstID") |>
merge(wage,  by = "ONSConstID")
df$vote_share <- df$RUK / df$Valid.votes
df <- df[df$RUK > 0, ]
library(ggplot2)
ggplot(df, aes(vote_share)) +
geom_histogram(binwidth = 0.025, fill = "turquoise4", colour = "white") +
labs(title = "Distribution of Reform UK vote share across constituencies",
x = "Vote share", y = "Count") +
theme_minimal()
summary(df$vote_share)
cont_vars <- c("pct18.24", "pct65.up", "white", "asian", "black",
"Qual4_pct", "Qual5_pct", "claimant_rate", "MedianWage")
uni <- lapply(cont_vars, function(v) {
ct <- cor.test(df$vote_share, df[[v]])
data.frame(variable = v,
slope = coef(lm(df$vote_share ~ df[[v]]))[2],
correlation = unname(ct$estimate),
p_value = ct$p.value)
}) |> do.call(what = rbind)
uni[order(uni$p_value), ]
aov_region <- aov(vote_share ~ Region, data = df)
summary(aov_region)
tapply(df$vote_share, df$Region, mean) |> sort()
p_region <- summary(aov_region)[[1]]["Region", "Pr(>F)"]
ranking <- rbind(
data.frame(variable = cont_vars, p_value = uni$p_value),
data.frame(variable = "Region", p_value = p_region)
)
ranking$p_adj <- p.adjust(ranking$p_value, method = "bonferroni")
ranking[order(ranking$p_adj), ]
multi <- lm(vote_share ~ pct18.24 + pct65.up + white + asian + black +
Qual4_pct + Qual5_pct + claimant_rate + MedianWage + Region,
data = df)
summary(multi)
par(mfrow = c(2, 2))
plot(multi)
par(mfrow = c(1, 1))
s <- summary(multi)
e <- residuals(multi); h <- hatvalues(multi)
data.frame(
df_model      = length(coef(multi)) - 1,
df_error      = df.residual(multi),
R_squared     = s$r.squared,
adj_R_squared = s$adj.r.squared,
residual_SE   = s$sigma,
AIC           = AIC(multi),
PRESS         = sum((e / (1 - h))^2)
)
coef_tab <- s$coefficients
p_cont_multi <- coef_tab[cont_vars, "Pr(>|t|)"]
p_region_multi <- anova(multi)["Region", "Pr(>F)"]
compare <- data.frame(
variable = c(cont_vars, "Region"),
p_univariate = ranking$p_value[match(c(cont_vars, "Region"), ranking$variable)],
p_multivariate = c(p_cont_multi, p_region_multi)
)
compare[order(compare$p_multivariate), ]
par(mfrow = c(1, 2))
plot(df$Qual5_pct, df$vote_share, pch = 16, col = "turquoise4",
xlab = "Proportion with no qualifications", ylab = "Reform vote share",
main = "Vote share vs education")
abline(lm(vote_share ~ Qual5_pct, data = df), col = "firebrick", lwd = 2)
plot(df$pct65.up, df$vote_share, pch = 16, col = "turquoise4",
xlab = "Proportion aged 65+", ylab = "Reform vote share",
main = "Vote share vs older population")
abline(lm(vote_share ~ pct65.up, data = df), col = "firebrick", lwd = 2)
par(mfrow = c(1, 1))
